{{ define "email.default.subject" }}
[DA5402-A5][{{ .Status | toUpper }}] {{ .GroupLabels.alertname }}
{{ end }}

{{ define "email.default.html" }}
<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: Arial, sans-serif; font-size: 14px; color: #333; }
    h2   { color: {{ if eq .Status "firing" }}#cc0000{{ else }}#007700{{ end }}; }
    table { border-collapse: collapse; width: 100%; }
    td, th { padding: 8px; border: 1px solid #ddd; text-align: left; }
    th { background-color: #f4f4f4; }
    .resolved { color: #007700; }
    .firing   { color: #cc0000; }
  </style>
</head>
<body>
  <h2>{{ if eq .Status "firing" }}🚨 Alert Firing{{ else }}✅ Alert Resolved{{ end }}</h2>
  <p><b>Group:</b> {{ .GroupLabels.alertname }}</p>
  <table>
    <tr><th>Alert</th><th>Severity</th><th>Summary</th><th>Started</th></tr>
    {{ range .Alerts }}
    <tr>
      <td>{{ .Labels.alertname }}</td>
      <td class="{{ .Labels.severity }}">{{ .Labels.severity }}</td>
      <td>{{ .Annotations.summary }}</td>
      <td>{{ .StartsAt.Format "2006-01-02 15:04:05 UTC" }}</td>
    </tr>
    {{ end }}
  </table>
  <p style="font-size:12px;color:#999;">
    Generated by Prometheus AlertManager · DA5402 A5
  </p>
</body>
</html>
{{ end }}
