{
  "title": "Heart Disease — MLOps Monitoring",
  "uid": "hd-mlops-drift",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 9,
      "type": "stat",
      "title": "Model Serving Endpoint",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "streamlit_model_endpoint_up", "legendFormat": "Status" }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Total Predictions",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "streamlit_predictions_served_total",
          "legendFormat": "predictions"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Drifted Features",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "streamlit_drift_features",
          "legendFormat": "drifted"
        }
      ],
      "options": {
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Drift Fraction",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "streamlit_drift_score",
          "legendFormat": "drift fraction"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last Batch Size",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "streamlit_last_batch_size",
          "legendFormat": "rows"
        }
      ],
      "options": {
        "colorMode": "value"
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Inference Latency",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(streamlit_inference_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95 Latency" },
        { "expr": "sum(rate(streamlit_inference_latency_seconds_sum[5m])) / sum(rate(streamlit_inference_latency_seconds_count[5m]))", "legendFormat": "Average Latency" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Inference Error Rate",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(streamlit_inference_errors_total[1m])", "legendFormat": "Errors/sec" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "custom": { "fillOpacity": 20 } } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Prediction Rate (per minute)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(streamlit_predictions_served_total[1m])",
          "legendFormat": "pred/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Drift Score Over Time",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "streamlit_drift_score",
          "legendFormat": "drift score"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "custom": {
            "fillOpacity": 20,
            "lineStyle": { "fill": "solid" }
          }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "CPU & Memory Usage",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "streamlit_cpu_usage_percent",
          "legendFormat": "CPU %"
        },
        {
          "expr": "streamlit_memory_usage_bytes",
          "legendFormat": "Memory"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Memory" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.axisPlacement", "value": "left" }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "type": "heatmap",
      "title": "Prediction Probability Distribution",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(streamlit_prediction_prob_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false,
        "color": { "mode": "scheme", "scheme": "Oranges" },
        "yAxis": { "format": "short" }
      }
    }
  ]
}